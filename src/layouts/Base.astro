---
import "@pagefind/default-ui/css/ui.css";
import archiveIndex from "../data/archive-index.json";

interface Props {
	title?: string;
	description?: string;
}

const { title = "JAnime Archive", description = "JAnime forum archive" } = Astro.props;
const { categories } = archiveIndex;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style is:global>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
				background: #0f0f1a;
				color: #e8e8f0;
				line-height: 1.5;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
			}
			.archive-frame {
				flex: 1 1 auto;
				width: 100%;
				border: 0;
				display: none;
			}
			body.viewing-archive .archive-frame {
				display: block;
			}
			body.viewing-archive #home-view {
				display: none;
			}
			a {
				color: #7eb8ff;
			}
			a:hover {
				color: #a8d4ff;
			}
			.container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 1.5rem 1rem 3rem;
			}
			.archive-chrome {
				position: sticky;
				top: 0;
				z-index: 1000;
				width: 100%;
				background: linear-gradient(180deg, #12121f 0%, #0a0a12 100%);
				color: #e8e8f0;
				border-bottom: 3px solid #5a9fd4;
				box-shadow: 0 4px 14px rgba(0, 0, 0, 0.45);
			}
			.archive-chrome-inner {
				max-width: 1280px;
				margin: 0 auto;
				padding: 10px 20px;
				display: flex;
				align-items: center;
				gap: 14px;
				flex-wrap: wrap;
			}
			.archive-chrome-brand {
				color: #fff;
				text-decoration: none;
				font-weight: 700;
				white-space: nowrap;
			}
			.archive-chrome-brand:hover {
				color: #fff;
			}
			.archive-chrome-inner select {
				padding: 7px 10px;
				border: 1px solid #3d5a73;
				border-radius: 6px;
				background: #1a2430;
				color: #e8e8f0;
				font-size: 13px;
				max-width: 220px;
				font-family: inherit;
			}
			.header-search-form {
				width: 200px;
				margin: 0;
				flex: none;
			}
			.header-search-input {
				width: 100%;
				padding: 7px 10px;
				border: 1px solid #3d5a73;
				border-radius: 6px;
				background: #1a2430;
				color: #e8e8f0;
				font-size: 13px;
				font-family: inherit;
				box-sizing: border-box;
			}
			.header-search-input::placeholder {
				color: #9898b0;
			}
			.header-search-input:hover,
			.header-search-input:focus {
				border-color: #5a9fd4;
				outline: none;
			}
			.search-modal {
				display: none;
				position: fixed;
				inset: 0;
				z-index: 10000;
				align-items: flex-start;
				justify-content: center;
				padding: 6vh 1.5rem 2rem;
			}
			.search-modal.is-open {
				display: flex;
			}
			.search-modal-backdrop {
				position: absolute;
				inset: 0;
				background: rgba(0, 0, 0, 0.65);
			}
			.search-modal-panel {
				position: relative;
				width: min(1200px, 96vw);
				max-height: min(88vh, 920px);
				overflow: auto;
				background: #1a1a2e;
				border: 1px solid #3a3a55;
				border-radius: 10px;
				box-shadow: 0 24px 64px rgba(0, 0, 0, 0.55);
				padding: 1.25rem 1.5rem 1.5rem;
			}
			.search-modal-panel .pagefind-ui__form {
				margin-bottom: 0.5rem;
			}
			.search-modal-panel #search .pagefind-ui__results-area {
				min-width: 100%;
				flex: 1 1 100%;
			}
			.search-modal-panel #search .pagefind-ui__results {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1rem;
				padding: 0;
				margin: 0;
			}
			.search-modal-panel #search .pagefind-ui__results > .pagefind-ui__result {
				display: flex;
				flex-direction: column;
				align-items: stretch;
				gap: 0.5rem;
				margin: 0;
				padding: 1rem 1.05rem;
				border: 1px solid #3a3a55;
				border-radius: 8px;
				background: #141424;
			}
			.search-modal-panel
				#search
				.pagefind-ui__results
				> .pagefind-ui__result:last-of-type {
				border-bottom: 1px solid #3a3a55;
			}
			.search-modal-panel #search .pagefind-ui__result-inner {
				flex: 1;
				margin-top: 0;
				width: 100%;
			}
			.search-modal-panel #search .pagefind-ui__result-title {
				font-size: 1rem;
				line-height: 1.35;
			}
			.search-modal-panel #search .pagefind-ui__result-excerpt {
				min-width: 0;
				font-size: 0.88rem;
				line-height: 1.45;
				margin-top: 0.35rem;
			}
			.search-modal-panel #search .pagefind-ui__result-tags {
				margin-top: 0.65rem;
				gap: 0.4rem;
			}
			.search-modal-panel #search .pagefind-ui__result-tag {
				font-size: 0.72rem;
				padding: 0.15rem 0.45rem;
			}
			.search-modal-panel #search .pagefind-ui__result-thumb {
				display: none;
			}
			.search-modal-panel #search .pagefind-ui__result-nested {
				padding-left: 0.65rem;
				border-left: 2px solid #3a3a55;
				margin-top: 0.5rem;
			}
			.search-modal-panel #search .pagefind-ui__button {
				margin-top: 1rem;
				max-width: 320px;
			}
			header.site-header {
				border-bottom: 1px solid #2a2a40;
				padding: 1rem 0 1.25rem;
				margin-bottom: 1.5rem;
			}
			header.site-header h1 {
				margin: 0 0 0.25rem;
				font-size: 1.75rem;
				font-weight: 700;
			}
			header.site-header p {
				margin: 0;
				color: #9898b0;
				font-size: 0.95rem;
			}
			.category-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.25rem;
				margin-top: 1.5rem;
			}
			.category-card {
				background: #1a1a2e;
				border: 1px solid #2a2a40;
				border-radius: 8px;
				padding: 1rem 1.1rem 1.15rem;
				scroll-margin-top: 5rem;
			}
			.category-card h2 {
				margin: 0 0 0.75rem;
				font-size: 1.05rem;
				color: #c8c8e0;
				border-bottom: 1px solid #2a2a40;
				padding-bottom: 0.5rem;
			}
			.category-card ul {
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.category-card li {
				margin: 0.35rem 0;
				font-size: 0.92rem;
			}
			.category-card .thread-title {
				font-weight: 600;
			}
			.category-card .page-links {
				margin: 0.15rem 0 0 0.75rem;
				font-size: 0.82rem;
				color: #9898b0;
			}
			.pagefind-ui {
				--pagefind-ui-scale: 0.95;
				--pagefind-ui-primary: #7eb8ff;
				--pagefind-ui-text: #e8e8f0;
				--pagefind-ui-background: #1a1a2e;
				--pagefind-ui-border: #3a3a55;
				--pagefind-ui-tag: #2a2a45;
			}
		</style>
	</head>
	<body>
		<header class="archive-chrome">
			<div class="archive-chrome-inner">
				<a href="/" class="archive-chrome-brand">JAnime Archive</a>
				<select id="archive-category-nav" aria-label="Browse archives">
					<option value="">Browse archives…</option>
				</select>
				<form class="header-search-form" id="header-search-form" role="search">
					<input
						type="search"
						class="header-search-input"
						id="header-search-input"
						placeholder="Search…"
						aria-label="Search archive"
					/>
				</form>
			</div>
		</header>

		<div class="search-modal" id="search-modal" aria-hidden="true">
			<div class="search-modal-backdrop" id="search-backdrop"></div>
			<div class="search-modal-panel" role="dialog" aria-label="Search archive">
				<div id="search"></div>
			</div>
		</div>

		<div class="container" id="home-view">
			<slot />
		</div>
		<iframe
			id="archive-frame"
			class="archive-frame"
			title="Archive viewer"
		></iframe>
		<script>
			let loadedRoute = "";

			const frame = document.getElementById("archive-frame");
			const searchModal = document.getElementById("search-modal");

			const closeSearchModal = () => {
				searchModal?.classList.remove("is-open");
				searchModal?.setAttribute("aria-hidden", "true");
			};

			const normalizeArchiveRoute = (href) => {
				const raw = href.startsWith("/") ? href : `/${href}`;
				const hashIdx = raw.indexOf("#");
				const pathPart = hashIdx >= 0 ? raw.slice(0, hashIdx) : raw;
				const anchor = hashIdx >= 0 ? raw.slice(hashIdx) : "";
				const path = pathPart.endsWith("/") ? pathPart : `${pathPart}/`;
				return `${path}${anchor}`;
			};

			const routeToHash = (route) => `#${route}`;

			const loadArchiveFrame = (route) => {
				if (!(frame instanceof HTMLIFrameElement)) return;
				try {
					const win = frame.contentWindow;
					if (win?.location.pathname.startsWith("/a/")) {
						win.location.replace(route);
					} else {
						frame.src = route;
					}
				} catch {
					frame.src = route;
				}
				loadedRoute = route;
			};

			const applyHash = () => {
				const hash = location.hash;
				if (hash.startsWith("#/a/")) {
					const route = normalizeArchiveRoute(hash.slice(1));
					document.body.classList.add("viewing-archive");
					if (loadedRoute !== route) {
						loadArchiveFrame(route);
					}
				} else {
					document.body.classList.remove("viewing-archive");
					loadedRoute = "";
					if (frame instanceof HTMLIFrameElement) {
						frame.removeAttribute("src");
					}
				}
			};

			const navigateArchive = (href, { replace = false } = {}) => {
				const route = normalizeArchiveRoute(href);
				const hash = routeToHash(route);
				if (replace) {
					history.replaceState({ archive: route }, "", hash);
				} else {
					history.pushState({ archive: route }, "", hash);
				}
				applyHash();
				closeSearchModal();
			};

			document.addEventListener("click", (e) => {
				const target = e.target;
				if (!(target instanceof Element)) return;
				const link = target.closest('a[href^="/a/"]');
				if (!link || !(link instanceof HTMLAnchorElement)) return;
				e.preventDefault();
				const href = link.getAttribute("href");
				if (!href) return;
				navigateArchive(href);
			});

			window.addEventListener("popstate", () => {
				applyHash();
			});

			window.addEventListener("hashchange", () => {
				applyHash();
			});

			window.addEventListener("message", (e) => {
				if (e.origin !== window.location.origin) return;
				if (e.data?.type === "archive-nav" && typeof e.data.route === "string") {
					navigateArchive(e.data.route);
				}
			});

			frame?.addEventListener("load", () => {
				if (!(frame instanceof HTMLIFrameElement)) return;
				try {
					const win = frame.contentWindow;
					if (!win) return;
					const route = normalizeArchiveRoute(
						win.location.pathname + win.location.search + win.location.hash,
					);
					if (!route.startsWith("/a/")) return;
					const newHash = routeToHash(route);
					if (location.hash !== newHash) {
						history.replaceState({ archive: route }, "", newHash);
						loadedRoute = route;
					}
				} catch {
					/* same-origin only */
				}
			});

			applyHash();
		</script>
		<script define:vars={{ categories }}>
			const nav = document.getElementById("archive-category-nav");
			if (nav) {
				for (const cat of categories) {
					const opt = document.createElement("option");
					opt.value = `/#cat-${cat.slug}`;
					opt.textContent = cat.name;
					nav.appendChild(opt);
				}
				nav.addEventListener("change", () => {
					if (nav.value) window.location = nav.value;
				});
			}
		</script>
		<script>
			import { PagefindUI } from "@pagefind/default-ui";

			const modal = document.getElementById("search-modal");
			const headerForm = document.getElementById("header-search-form");
			const headerInput = document.getElementById("header-search-input");
			const backdrop = document.getElementById("search-backdrop");
			const searchEl = document.getElementById("search");
			const params = new URLSearchParams(window.location.search);
			const initialQuery = params.get("q") || "";

			/** @type {PagefindUI | null} */
			let pagefindUI = null;
			let pendingQuery = null;

			const syncSearchParam = (q) => {
				const url = new URL(location.href);
				url.searchParams.set("q", q);
				history.replaceState(null, "", url);
			};

			const openModal = () => {
				modal?.classList.add("is-open");
				modal?.setAttribute("aria-hidden", "false");
			};

			const closeModal = () => {
				modal?.classList.remove("is-open");
				modal?.setAttribute("aria-hidden", "true");
			};

			const runSearch = (query) => {
				openModal();
				if (pagefindUI) {
					pagefindUI.triggerSearch(query);
					requestAnimationFrame(() => {
						const input = searchEl?.querySelector(
							".pagefind-ui__search-input",
						);
						if (input instanceof HTMLInputElement) input.focus();
					});
				} else {
					pendingQuery = query;
				}
			};

			headerForm?.addEventListener("submit", (e) => {
				e.preventDefault();
				const q =
					headerInput instanceof HTMLInputElement
						? headerInput.value.trim()
						: "";
				if (!q) return;
				syncSearchParam(q);
				runSearch(q);
			});

			backdrop?.addEventListener("click", closeModal);
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape" && modal?.classList.contains("is-open")) {
					closeModal();
				}
			});

			if (!searchEl) throw new Error("Missing #search element");

			fetch("/pagefind/pagefind.js", { method: "HEAD" })
				.then((res) => {
					if (!res.ok) throw new Error("Pagefind index missing");
					pagefindUI = new PagefindUI({
						element: "#search",
						showSubResults: true,
						showImages: false,
						excerptLength: 24,
					});
					const query = pendingQuery ?? initialQuery;
					if (query && headerInput instanceof HTMLInputElement) {
						headerInput.value = query;
						if (initialQuery) syncSearchParam(query);
						runSearch(query);
					}
					pendingQuery = null;
				})
				.catch(() => {
					searchEl.innerHTML =
						'<p style="color:#9898b0">Search index not built yet. Run <code>pnpm archive</code>.</p>';
				});
		</script>
	</body>
</html>
