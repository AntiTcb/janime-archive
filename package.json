{
    "name": "arynis-archive",
    "type": "module",
    "version": "0.0.1",
    "engines": {
        "node": ">=24.12.0",
        "pnpm": ">=11.1.3"
    },
    "scripts": {
        "download-archives": "node scripts/download-archives.mjs",
        "archive": "node scripts/build-archive.mjs && pagefind --site public",
        "dev": "astro dev",
        "build": "node scripts/download-archives.mjs && node scripts/build-archive.mjs && astro build && pagefind --site dist",
        "preview": "astro preview",
        "deploy": "pnpm build && wrangler deploy",
        "astro": "astro"
    },
    "dependencies": {
        "@pagefind/default-ui": "^1.5.2",
        "astro": "^6.4.4"
    },
    "devDependencies": {
        "7zip-min": "^3.0.1",
        "cheerio": "^1.2.0",
        "pagefind": "^1.5.2",
        "wrangler": "^4.98.0"
    }
}
