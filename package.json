{
    "name": "arynis-archive",
    "type": "module",
    "version": "0.0.1",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "archive": "node scripts/build-archive.mjs && pagefind --site public",
        "dev": "astro dev",
        "build": "node scripts/build-archive.mjs && astro build && pagefind --site dist",
        "preview": "astro preview",
        "deploy": "pnpm build && wrangler deploy",
        "astro": "astro"
    },
    "dependencies": {
        "@pagefind/default-ui": "^1.5.2",
        "astro": "^6.4.4"
    },
    "devDependencies": {
        "cheerio": "^1.2.0",
        "pagefind": "^1.5.2",
        "wrangler": "^4.1.0"
    }
}
